NODE_ENV=development
DATABASE_URL=postgresql://clinic_os:clinic_os@localhost:5432/clinic_os
PUBLIC_APP_ORIGIN=http://localhost:3000
INTERNAL_API_BASE_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_PROXY_PATH=/clinic-api
# Legacy fallback for internal proxy development only.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
AUTH_MODE=dev_headers
NEXT_PUBLIC_AUTH_MODE=dev_headers
OPENAI_API_KEY=

# Optional future infrastructure. Only required when AUTH_MODE=trusted_proxy.
TRUSTED_PROXY_SHARED_SECRET=
TRUSTED_PROXY_ALLOWED_SKEW_SECONDS=300

MICROSOFT_INTEGRATION_MODE=stub
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SHAREPOINT_SITE_ID=
MICROSOFT_SHAREPOINT_POLICY_FOLDER=ClinicOS/approved-documents
MICROSOFT_LISTS_SITE_ID=
MICROSOFT_PLANNER_PLAN_ID=
MICROSOFT_PLANNER_BUCKET_ID=
MICROSOFT_TEAMS_APPROVALS_WEBHOOK_URL=
MICROSOFT_TEAMS_OFFICE_OPS_WEBHOOK_URL=
MICROSOFT_LIST_ISSUES_ID=
MICROSOFT_LIST_ACTION_ITEMS_ID=
MICROSOFT_LIST_IMPORT_STATUS_ID=
MICROSOFT_LIST_INCIDENTS_ID=
MICROSOFT_LIST_CAPA_ID=

WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL_MS=5000

# Local development should stay on dev_headers/stub.
# Pilot device rollout should move to device_profiles on a same-origin deployment,
# where the browser only talks to /clinic-api/* on the public site and the Next app
# proxies requests to INTERNAL_API_BASE_URL.
#
# bootstrap the first admin with:
# npm --workspace @clinic-os/api run auth:bootstrap-admin -- --displayName "Pilot Admin" --role medical_director --pin 123456
# and validate Microsoft before enabling live mode.
# Live Microsoft mode uses Graph app credentials for SharePoint, Lists, and Planner,
# plus Teams webhook URLs for approval and office-ops notifications.
