{
  "name": "clinic-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm --workspace @clinic-os/db run prisma:generate",
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm --workspace @clinic-os/web run dev",
    "dev:api": "npm --workspace @clinic-os/api run dev",
    "dev:worker": "npm --workspace @clinic-os/worker run dev",
    "lint": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "codex:doctor": "bash ./scripts/validate-tree.sh",
    "codex:prompts": "node ./scripts/print-codex-kickoff.mjs",
    "smoke:render": "node ./scripts/render-smoke.mjs"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^22.10.2",
    "prisma": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
