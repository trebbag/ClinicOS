    "@clinic-os/agents": "0.1.0",
    "@clinic-os/approvals": "0.1.0",
    "@clinic-os/domain": "0.1.0",
    "@clinic-os/metrics": "0.1.0",
    "@clinic-os/tools": "0.1.0",
    "@clinic-os/workflows": "0.1.0",
    "@fastify/cors": "^10.0.1",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0"
  }
}
